*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
Pods/

# Apple signing credentials (lives outside repo anyway, but belt-and-suspenders)
*.p8
*.p12
*.cer
*.mobileprovision
*.jks
*.key

# Logs
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# Metro
.metro-health-check*

# Supabase CLI local cache (regenerated by `supabase link`)
